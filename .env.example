# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PROVIDER=sqlite
DATABASE_URL=postgresql://user:password@localhost:5432/finflow

# ─── Google OAuth2 (Gmail + Login) ────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Enable: Gmail API + People API
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ─── Anthropic (Claude for email parsing) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=your_32_byte_session_secret_here
# Generate: openssl rand -hex 32 (must be exactly 64 hex chars = 32 bytes)
TOKEN_ENCRYPTION_KEY=your_64_char_hex_string_token_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001
